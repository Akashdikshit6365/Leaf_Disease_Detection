# ─────────────────────────────────────────────────────────
# Backend configuration — copy to backend/.env and fill in
# ─────────────────────────────────────────────────────────

# App
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Groq (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# Cloudinary
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_IMAGE_FOLDER=LeafAI/images
CLOUDINARY_HEATMAP_FOLDER=LeafAI/heatmaps

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=leafai

# Model
# Relative paths are resolved from backend/
MODEL_WEIGHTS_PATH=./ml_model/weights.pth
MODEL_CONFIDENCE_THRESHOLD=0.75
MODEL_CONFIDENCE_MARGIN_THRESHOLD=0.15
IMAGE_QUALITY_MIN_DIMENSION=224
IMAGE_QUALITY_MIN_BRIGHTNESS=0.18
IMAGE_QUALITY_MAX_BRIGHTNESS=0.92
IMAGE_QUALITY_MIN_BLUR_SCORE=40.0
IMAGE_QUALITY_MIN_PLANT_COVERAGE=0.15
IMAGE_QUALITY_MIN_CENTER_COVERAGE=0.12
