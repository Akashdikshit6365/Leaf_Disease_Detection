# Backend configuration - copy to backend/.env and fill in.

# App
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
# Add your laptop LAN origin when testing from a phone, for example:
# http://192.168.1.10:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,capacitor://localhost

# Groq (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Gemini (image diagnosis)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_VISION_MODEL=gemini-3.1-flash-lite

# Cloudinary
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_IMAGE_FOLDER=LeafAI/images
CLOUDINARY_HEATMAP_FOLDER=LeafAI/heatmaps

# MongoDB Atlas
MONGODB_URI=mongodb+srv://leafai_app:your_password@your_cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=leafai

# Auth
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Model
# Relative paths are resolved from backend/.
MODEL_WEIGHTS_PATH=./ml_model/weights.pth
MODEL_CONFIDENCE_THRESHOLD=0.60
MODEL_CONFIDENCE_MARGIN_THRESHOLD=0.05
IMAGE_QUALITY_MIN_DIMENSION=160
IMAGE_QUALITY_MIN_BRIGHTNESS=0.08
IMAGE_QUALITY_MAX_BRIGHTNESS=0.98
IMAGE_QUALITY_MIN_BLUR_SCORE=15.0
IMAGE_QUALITY_MIN_PLANT_COVERAGE=0.08
IMAGE_QUALITY_MIN_CENTER_COVERAGE=0.03
